<!DOCTYPE html>
<html lang="id">
    <head>
        <meta charset="utf-8">
        <title>{{title}}</title>
        <meta content="width=device-width, initial-scale=1.0" name="viewport">
        <meta content="Portfolio Afif Fathur - Mahasiswa Informatika UNP" name="description">

        <link href="/img/luffy.png" rel="icon">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

        <link href="/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
        <link href="/lib/animate/animate.min.css" rel="stylesheet">
        <link href="/css/bootstrap.min.css" rel="stylesheet">
        <link href="/css/animate.css" rel="stylesheet">
    </head>

    <body class="tentang-page">
        {{>header}}

        <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="sr-only">Loading...</span>
            </div>
        </div>

        <div class="container py-4">
            <div class="row g-5">
                <div class="col-lg-4 sticky-lg-top vh-100">
                    <div class="d-flex flex-column h-100 text-center overflow-auto shadow sidebar-profile">
                        <img class="w-100 img-fluid mb-4 profile-photo" src="/img/foto2.png" alt="Afif Fathur">
                        <h1 class="text-primary mt-2">{{name}}</h1>
                        <div class="mb-4" style="height: 22px;">
                            <h4 class="typed-text-output d-inline-block text-light"></h4>
                            <div class="typed-text d-none">Game Developer Wannabe, Mahasiswa Informatika, Web Developer</div>
                        </div>
                        <div class="d-flex justify-content-center mb-3">
                            <a class="btn btn-secondary btn-square mx-1" href="{{github}}" target="_blank" rel="noopener noreferrer" title="GitHub">
                                <i class="fab fa-github"></i>
                            </a>
                            <a class="btn btn-secondary btn-square mx-1" href="{{instagram}}" target="_blank" rel="noopener noreferrer" title="Instagram">
                                <i class="fab fa-instagram"></i>
                            </a>
                            <a class="btn btn-secondary btn-square mx-1" href="mailto:{{email}}" title="Email">
                                <i class="fas fa-envelope"></i>
                            </a>
                        </div>
                        <div class="d-flex align-items-end justify-content-between border-top mt-auto">
                            <a href="{{github}}" target="_blank" rel="noopener noreferrer" class="btn w-50 border-end">
                                <i class="fab fa-github me-1"></i> GitHub
                            </a>
                            <a href="#contact" class="btn w-50 btn-scroll">Hubungi Saya</a>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <section class="py-5 border-bottom wow fadeInUp" data-wow-delay="0.1s">
                        <h1 class="title pb-3 mb-5">Tentang Saya</h1>
                        <p>
                            Perkenalkan, saya Afif Fathur — mahasiswa Informatika di Universitas Negeri Padang.
                            Saya tertarik pada pengembangan web, pemrograman, dan game development.
                            Saat ini saya sedang belajar Unity Engine dan terus mengasah kemampuan coding
                            melalui berbagai proyek praktik.
                        </p>
                        <div class="row mb-4">
                            <div class="col-sm-6 py-1">
                                <span class="fw-medium text-primary">Nama:</span> {{name}}
                            </div>
                            <div class="col-sm-6 py-1">
                                <span class="fw-medium text-primary">Tanggal Lahir:</span> 5 April 2003
                            </div>
                            <div class="col-sm-6 py-1">
                                <span class="fw-medium text-primary">Pendidikan:</span> S1 Informatika
                            </div>
                            <div class="col-sm-6 py-1">
                                <span class="fw-medium text-primary">Universitas:</span> UNP Padang
                            </div>
                            <div class="col-sm-6 py-1">
                                <span class="fw-medium text-primary">Email:</span>
                                <a href="mailto:{{email}}" class="text-light">{{email}}</a>
                            </div>
                            <div class="col-sm-6 py-1">
                                <span class="fw-medium text-primary">Lokasi:</span> Siteba, Padang
                            </div>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="d-flex bg-secondary p-4 stat-card">
                                    <h1 class="flex-shrink-0 display-5 text-primary mb-0" data-toggle="counter-up">3</h1>
                                    <div class="ps-3">
                                        <p class="mb-0">Tahun</p>
                                        <h5 class="mb-0">Belajar Coding</h5>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex bg-secondary p-4 stat-card">
                                    <h1 class="flex-shrink-0 display-5 text-primary mb-0" data-toggle="counter-up">5</h1>
                                    <div class="ps-3">
                                        <p class="mb-0">Proyek</p>
                                        <h5 class="mb-0">Selesai</h5>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex bg-secondary p-4 stat-card">
                                    <h1 class="flex-shrink-0 display-5 text-primary mb-0" data-toggle="counter-up">10</h1>
                                    <div class="ps-3">
                                        <p class="mb-0">Bahasa</p>
                                        <h5 class="mb-0">Pemrograman</h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="py-5 border-bottom wow fadeInUp" data-wow-delay="0.1s">
                        <h1 class="title pb-3 mb-5">Keahlian</h1>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="skill mb-4">
                                    <div class="d-flex justify-content-between">
                                        <p class="mb-2">HTML &amp; CSS</p>
                                        <p class="mb-2">75%</p>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-primary" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                                <div class="skill mb-4">
                                    <div class="d-flex justify-content-between">
                                        <p class="mb-2">JavaScript &amp; Node.js</p>
                                        <p class="mb-2">65%</p>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-warning" role="progressbar" aria-valuenow="65" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                                <div class="skill mb-4">
                                    <div class="d-flex justify-content-between">
                                        <p class="mb-2">Python</p>
                                        <p class="mb-2">60%</p>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-danger" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="skill mb-4">
                                    <div class="d-flex justify-content-between">
                                        <p class="mb-2">C / C++</p>
                                        <p class="mb-2">55%</p>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-danger" role="progressbar" aria-valuenow="55" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                                <div class="skill mb-4">
                                    <div class="d-flex justify-content-between">
                                        <p class="mb-2">PHP &amp; MySQL</p>
                                        <p class="mb-2">50%</p>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-success" role="progressbar" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                                <div class="skill mb-4">
                                    <div class="d-flex justify-content-between">
                                        <p class="mb-2">Unity Engine</p>
                                        <p class="mb-2">30%</p>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar bg-info" role="progressbar" aria-valuenow="30" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="py-5 border-bottom wow fadeInUp" data-wow-delay="0.1s">
                        <h1 class="title pb-3 mb-5">Pengalaman</h1>
                        <div class="border-start border-2 border-light pt-2 ps-5">
                            <div class="position-relative mb-4">
                                <span class="bi bi-arrow-right fs-4 text-light position-absolute" style="top: -5px; left: -50px;"></span>
                                <h5 class="mb-1">Belajar Bahasa C/C++</h5>
                                <p class="mb-2 text-primary"><small>2021 – 2022</small></p>
                                <p>Semester pertama fokus mempelajari dasar pemrograman dengan Bahasa C/C++.</p>
                            </div>
                            <div class="position-relative mb-4">
                                <span class="bi bi-arrow-right fs-4 text-light position-absolute" style="top: -5px; left: -50px;"></span>
                                <h5 class="mb-1">Pengembangan Web</h5>
                                <p class="mb-2 text-primary"><small>2022 – 2023</small></p>
                                <p>Mulai belajar HTML, CSS, JavaScript, PHP, dan Python untuk membangun website.</p>
                            </div>
                            <div class="position-relative mb-4">
                                <span class="bi bi-arrow-right fs-4 text-light position-absolute" style="top: -5px; left: -50px;"></span>
                                <h5 class="mb-1">Node.js &amp; Express</h5>
                                <p class="mb-2 text-primary"><small>2023</small></p>
                                <p>Mempelajari backend development dengan Node.js, Express, dan Handlebars.</p>
                            </div>
                        </div>
                    </section>

                    <section class="py-5 border-bottom wow fadeInUp" data-wow-delay="0.1s">
                        <h1 class="title pb-3 mb-5">Proyek</h1>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="project-card bg-secondary p-4 h-100">
                                    <i class="fa fa-2x fa-cloud-sun text-primary mb-3"></i>
                                    <h5 class="mb-2">Aplikasi Cek Cuaca</h5>
                                    <p class="mb-3">Web app untuk mengecek informasi cuaca real-time berdasarkan lokasi, dibangun dengan Node.js dan Express.</p>
                                    <a href="/cuaca" class="btn btn-primary btn-sm">Lihat Aplikasi</a>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="project-card bg-secondary p-4 h-100">
                                    <i class="fab fa-2x fa-github text-primary mb-3"></i>
                                    <h5 class="mb-2">GitHub Portfolio</h5>
                                    <p class="mb-3">Kumpulan proyek dan kode saya di GitHub. Lihat repositori dan kontribusi terbaru.</p>
                                    <a href="{{github}}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
                                        <i class="fab fa-github me-1"></i> Kunjungi GitHub
                                    </a>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="py-5 wow fadeInUp" data-wow-delay="0.1s" id="contact">
                        <h1 class="title pb-3 mb-5">Hubungi Saya</h1>
                        <p class="mb-4">Tertarik berkolaborasi atau punya pertanyaan? Kirim pesan melalui form di bawah atau hubungi langsung via email.</p>
                        <form id="contact-form">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control border-0 bg-secondary" id="name" placeholder="Nama Anda" required>
                                        <label for="name">Nama Anda</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="email" class="form-control border-0 bg-secondary" id="email-input" placeholder="Email Anda" required>
                                        <label for="email-input">Email Anda</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <input type="text" class="form-control border-0 bg-secondary" id="subject" placeholder="Subjek" required>
                                        <label for="subject">Subjek</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <textarea class="form-control border-0 bg-secondary" placeholder="Tulis pesan..." id="message" style="height: 200px" required></textarea>
                                        <label for="message">Pesan</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div id="form-feedback" class="alert d-none mb-3" role="alert"></div>
                                    <button class="btn btn-primary w-100 py-3" type="submit">
                                        <i class="fas fa-paper-plane me-2"></i>Kirim Pesan
                                    </button>
                                </div>
                            </div>
                        </form>
                    </section>

                    <section class="wow fadeIn" data-wow-delay="0.1s">
                        <div class="bg-secondary text-light text-center p-5 footer-section">
                            <div class="d-flex justify-content-center mb-4">
                                <a class="btn btn-dark btn-square mx-1" href="{{github}}" target="_blank" rel="noopener noreferrer" title="GitHub">
                                    <i class="fab fa-github"></i>
                                </a>
                                <a class="btn btn-dark btn-square mx-1" href="{{instagram}}" target="_blank" rel="noopener noreferrer" title="Instagram">
                                    <i class="fab fa-instagram"></i>
                                </a>
                                <a class="btn btn-dark btn-square mx-1" href="mailto:{{email}}" title="Email">
                                    <i class="fas fa-envelope"></i>
                                </a>
                            </div>
                            <p class="m-0">&copy; {{name}}. Dibuat dengan Node.js &amp; Express.</p>
                        </div>
                    </section>
                </div>
            </div>
        </div>

        <a href="#" class="back-to-top"><i class="fa fa-angle-double-up"></i></a>

        <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
        <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
        <script src="/lib/wow/wow.min.js"></script>
        <script src="/lib/typed/typed.min.js"></script>
        <script src="/lib/easing/easing.min.js"></script>
        <script src="/lib/waypoints/waypoints.min.js"></script>
        <script src="/lib/counterup/counterup.min.js"></script>
        <script src="/js/main.js"></script>
        <script src="/js/tentang.js"></script>
    </body>
</html>
